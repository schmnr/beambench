{
  "name": "beambench-ui",
  "private": true,
  "version": "0.1.10",
  "description": "Desktop software for preparing and running laser-cutting and engraving jobs.",
  "license": "GPL-3.0-or-later",
  "repository": "https://github.com/schmnr/beambench",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:perf": "vitest run src/canvas/canvasPerfBudget.perf.test.ts",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "licenses:generate": "node ../scripts/generate-license-report.mjs",
    "release:cli": "node scripts/build-cli-release.mjs",
    "update:manifest": "node scripts/create-update-manifest.mjs",
    "update:validate-manifest": "node scripts/validate-update-manifest.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "i18next": "^25.10.10",
    "i18next-icu": "^2.4.3",
    "intl-messageformat": "^10.7.18",
    "lucide-react": "^0.577.0",
    "rbush": "^4.0.1",
    "react": "^19",
    "react-dom": "^19",
    "react-i18next": "^15.7.4",
    "zustand": "^5"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/rbush": "^4.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "autoprefixer": "^10",
    "eslint": "^9",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-react-hooks": "^5",
    "jsdom": "^25",
    "postcss": "^8",
    "prettier": "^3",
    "tailwindcss": "^3",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vite": "^6",
    "vitest": "^3"
  }
}
